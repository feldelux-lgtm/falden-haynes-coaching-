---
// ServicesSection.astro — 3 easy steps
---

<section class="steps" id="what-i-do" aria-label="How it works">
  <div class="container">

    <div class="steps-header fade-in">
      <span class="steps-chip">How it works</span>
      <h2 class="steps-h2">3 easy steps</h2>
    </div>

    <div class="steps-scroll-wrap" id="steps-scroll">
    <div class="steps-grid fade-in">

      <!-- Step 1 -->
      <div class="step-card">
        <div class="step-top">
          <span class="step-badge">Step 01</span>
          <img
            src="/Images/glowing%20lightbulb.webp"
            alt="Lightbulb — got your idea"
            class="step-img"
            loading="lazy"
            width="120"
            height="120"
          />
        </div>
        <h3 class="step-title">Got your idea?</h3>
        <p class="step-body">
          You have something in mind — a business, a project, a change you want to make.
          That is the starting point. Bring it as it is. Half-formed is fine.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="step-card step-card--accent">
        <div class="step-top">
          <span class="step-badge step-badge--light">Step 02</span>
          <img
            src="/Images/checkmark.webp"
            alt="Checkmark — choose your pack"
            class="step-img"
            loading="lazy"
            width="120"
            height="120"
          />
        </div>
        <h3 class="step-title">Choose the pack that suits your idea</h3>
        <p class="step-body">
          Not sure which package fits? Take the quick quiz and I will point you
          in the right direction.
        </p>
        <a href="/contact#quiz" class="step-link">
          Take the quiz
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Step 3 -->
      <div class="step-card">
        <div class="step-top">
          <span class="step-badge">Step 03</span>
          <img
            src="/Images/rocket.webp"
            alt="Rocket — get a plan"
            class="step-img"
            loading="lazy"
            width="120"
            height="120"
          />
        </div>
        <h3 class="step-title">Get a plan to bring your idea to life</h3>
        <p class="step-body">
          Real, structured, actionable. A plan built around your idea, your resources,
          and what you want to achieve.
        </p>
        <a href="/contact" class="step-link">
          Book a free call
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

    </div>
    </div>

    <!-- Mobile carousel nav -->
    <div class="steps-carousel-nav" aria-label="Scroll steps">
      <button class="steps-carousel-btn" id="steps-prev" aria-label="Previous step">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="steps-dots" id="steps-dots" aria-hidden="true">
        <span class="steps-dot steps-dot--active"></span>
        <span class="steps-dot"></span>
        <span class="steps-dot"></span>
      </div>
      <button class="steps-carousel-btn" id="steps-next" aria-label="Next step">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

  </div>
</section>

<style>
  .steps {
    background: #ffffff;
    padding: 88px 0;
  }

  /* ── Header ──────────────────────────────── */
  .steps-header {
    text-align: center;
    margin-bottom: 52px;
  }
  .steps-chip {
    display: inline-flex;
    align-items: center;
    background: #e3dfff;
    color: #3b309e;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 7px 18px;
    border-radius: 9999px;
    margin-bottom: 20px;
  }
  .steps-h2 {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 48px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #1a1744;
    line-height: 1.1;
  }

  /* ── Grid ────────────────────────────────── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* ── Card ────────────────────────────────── */
  .step-card {
    background: #f8f9fb;
    border: 1px solid #ede9ff;
    border-radius: 24px;
    padding: 32px 28px 36px;
    display: flex;
    flex-direction: column;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  @media (hover: hover) {
    .step-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(59,48,158,0.1); }
  }
  .step-card--accent {
    background: #1a1744;
    border-color: #1a1744;
  }

  /* ── Top row: badge + image ──────────────── */
  .step-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .step-badge {
    display: inline-flex;
    align-items: center;
    background: #534AB7;
    color: #ffffff;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 9999px;
    flex-shrink: 0;
  }
  .step-badge--light {
    background: rgba(255,255,255,0.15);
    color: #ffffff;
  }

  .step-img {
    width: 96px;
    height: 96px;
    object-fit: contain;
    object-position: center;
    display: block;
    flex-shrink: 0;
  }

  /* ── Text ────────────────────────────────── */
  .step-title {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #1a1744;
    line-height: 1.25;
    margin-bottom: 12px;
  }
  .step-card--accent .step-title { color: #ffffff; }

  .step-body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    color: #7e7a9f;
    line-height: 1.75;
    flex: 1;
  }
  .step-card--accent .step-body { color: rgba(255,255,255,0.6); }

  .step-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #534ab7;
    text-decoration: none;
    margin-top: 20px;
    transition: gap 0.2s ease;
    align-self: flex-start;
  }
  .step-card--accent .step-link { color: #F2D832; }
  .step-link:hover { gap: 12px; }

  /* ── Carousel nav — hidden desktop ──────── */
  .steps-carousel-nav {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 20px;
  }
  .steps-carousel-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: #534AB7;
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: #ffffff;
    transition: background 0.2s, transform 0.1s;
    flex-shrink: 0;
  }
  .steps-carousel-btn:hover { background: #3b309e; }
  .steps-carousel-btn:active { transform: scale(0.95); }
  .steps-dots { display: flex; gap: 6px; align-items: center; }
  .steps-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #d5d1f0;
    transition: background 0.2s, width 0.2s;
  }
  .steps-dot--active { background: #534AB7; width: 20px; border-radius: 4px; }

  /* ── Tablet ──────────────────────────────── */
  @media (max-width: 960px) {
    .steps-grid { grid-template-columns: 1fr 1fr; }
    .step-card:last-child { grid-column: 1 / -1; }
  }

  /* ── Mobile carousel ─────────────────────── */
  @media (max-width: 640px) {
    .steps { padding: 56px 0; }
    .steps-h2 { font-size: 32px; }
    .steps-header { margin-bottom: 36px; }

    .steps-scroll-wrap {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      margin: 0 -16px;
      padding: 0 16px 4px;
    }
    .steps-scroll-wrap::-webkit-scrollbar { display: none; }

    .steps-grid {
      display: flex;
      flex-wrap: nowrap;
      width: max-content;
      gap: 14px;
      grid-template-columns: unset;
    }

    .step-card {
      width: 82vw;
      max-width: 320px;
      flex-shrink: 0;
      scroll-snap-align: center;
    }
    .step-card:last-child { grid-column: auto; }
    .step-img { width: 80px; height: 80px; }
    .step-title { font-size: 18px; }
    .step-body { font-size: 14px; }

    .steps-carousel-nav { display: flex; }
  }

  @media (max-width: 380px) {
    .steps { padding: 44px 0; }
    .steps-h2 { font-size: 28px; }
    .step-card { width: 88vw; padding: 24px 20px 28px; }
    .step-img { width: 68px; height: 68px; }
  }
</style>

<script>
  const wrap = document.getElementById('steps-scroll');
  const prev = document.getElementById('steps-prev');
  const next = document.getElementById('steps-next');
  const dots = document.querySelectorAll<HTMLElement>('#steps-dots .steps-dot');

  function cardWidth() {
    const c = wrap?.querySelector<HTMLElement>('.step-card');
    return c ? c.offsetWidth + 14 : 300;
  }
  function updateDots() {
    if (!wrap) return;
    const idx = Math.round(wrap.scrollLeft / cardWidth());
    dots.forEach((d, i) => d.classList.toggle('steps-dot--active', i === idx));
  }

  prev?.addEventListener('click', () => wrap?.scrollBy({ left: -cardWidth(), behavior: 'smooth' }));
  next?.addEventListener('click', () => wrap?.scrollBy({ left: cardWidth(), behavior: 'smooth' }));
  wrap?.addEventListener('scroll', updateDots, { passive: true });
</script>
